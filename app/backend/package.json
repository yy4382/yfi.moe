{
  "name": "@repo/backend",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts | pino-pretty",
    "build": "tsdown",
    "start": "node dist/index.mjs",
    "check-types": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "email:dev": "pnpx react-email dev --dir src",
    "clean": "rm -rf dist"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    }
  },
  "dependencies": {
    "@hono/node-server": "^2.0.6",
    "@hono/standard-validator": "^0.2.2",
    "@libsql/client": "^0.17.4",
    "@repo/api": "workspace:*",
    "@repo/helpers": "workspace:*",
    "@repo/markdown": "workspace:*",
    "@scalar/hono-api-reference": "^0.11.6",
    "@standard-community/standard-json": "^0.3.5",
    "@standard-community/standard-openapi": "^0.2.9",
    "@vitest/coverage-v8": "^4.1.9",
    "akismet-api": "^6.0.0",
    "better-auth": "catalog:",
    "drizzle-orm": "^0.45.2",
    "fp-ts": "^2.16.11",
    "hono": "catalog:",
    "hono-openapi": "^1.3.0",
    "hono-pino": "^0.10.3",
    "nodemailer": "^9.0.1",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "react": "catalog:",
    "react-email": "^6.6.5",
    "spark-md5": "^3.0.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "catalog:",
    "@types/json-schema": "^7.0.15",
    "@types/node": "catalog:",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "catalog:",
    "@types/spark-md5": "^3.0.5",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "eslint": "catalog:",
    "tsdown": "^0.22.3",
    "tsx": "^4.22.4",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:",
    "vitest": "catalog:"
  }
}
