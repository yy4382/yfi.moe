---
import Section from "@/components/ui/section.astro";
import NavLayout from "@/components/layouts/NavLayout.astro";
import { Image } from "astro:assets";
import logo from "@/assets/logo.png";
import { authorName, contactInfo, projects } from "@/config/author";
import { getSortedPosts } from "@/lib/utils/content";
import { format } from "date-fns";
import readingTime from "reading-time";
import { getSeo } from "@/lib/utils/SEO";
import {
  colors,
  motion,
  radii,
  spacing,
  typography,
} from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

const posts = await getSortedPosts();
const firstDate = posts.at(-1)!.data.publishedDate;
const statistics = {
  articles: posts.length,
  words: posts.reduce(
    (total, post) => total + readingTime(post.body!).words,
    0,
  ),
  tags: new Set(posts.flatMap((post) => post.data.tags)).size,
};
const seoConfig = getSeo({
  title: "首页",
  description: "笔记与分享，代码和生活",
});
const styles = stylex.create({
  hero: {
    alignItems: "center",
    display: "flex",
    flexDirection: "column",
    gap: spacing.lg,
    justifyContent: "center",
    minHeight: "24rem",
    "@media (min-width: 48rem)": { minHeight: "40rem" },
  },
  heroRow: {
    alignItems: "center",
    display: "flex",
    gap: spacing.lg,
    justifyContent: "center",
    "@media (min-width: 48rem)": { gap: spacing.xxl },
  },
  logo: { borderRadius: radii.md },
  heroTitle: {
    fontSize: "3rem",
    fontWeight: typography.weightBold,
    margin: 0,
    "@media (min-width: 64rem)": { fontSize: "6rem" },
  },
  spacer: { minHeight: "4.5rem" },
  featureSection: {
    paddingBottom: "4rem",
    paddingTop: "5rem",
    position: "relative",
    "@media (min-width: 40rem)": { paddingTop: spacing.xxl },
  },
  contactSection: {
    paddingBottom: spacing.xxl,
    paddingTop: "4.5rem",
    position: "relative",
    "@media (min-width: 40rem)": { paddingTop: spacing.xxl },
  },
  sectionNumber: {
    alignItems: "center",
    borderBottomColor: colors.borderDefault,
    borderBottomStyle: "solid",
    borderBottomWidth: "1px",
    borderRightColor: colors.borderDefault,
    borderRightStyle: "solid",
    borderRightWidth: "1px",
    boxSizing: "border-box",
    cursor: "default",
    display: "flex",
    fontFamily: typography.monoFamily,
    fontSize: typography.sizeLg,
    fontVariantNumeric: "slashed-zero",
    fontWeight: typography.weightSemibold,
    height: "3.125rem",
    justifyContent: "center",
    left: 0,
    lineHeight: "1.4375rem",
    margin: 0,
    pointerEvents: "none",
    position: "absolute",
    top: 0,
    width: "3.125rem",
    "@media (min-width: 40rem)": {
      borderRightWidth: 0,
      transform: "translateX(-100%)",
    },
    "@media (min-width: 80rem)": {
      borderLeftColor: colors.borderDefault,
      borderLeftStyle: "solid",
      borderLeftWidth: "1px",
    },
  },
  sectionTitle: {
    fontSize: "1.875rem",
    fontWeight: typography.weightBold,
    marginBlock: `0 ${spacing.sm}`,
    paddingInline: spacing.xxl,
    "@media (min-width: 40rem)": { paddingInline: "2.5rem" },
  },
  sectionDescription: {
    marginBottom: "3rem",
    marginTop: 0,
    maxWidth: "65ch",
    paddingInline: spacing.xxl,
    "@media (min-width: 40rem)": { paddingInline: "2.5rem" },
  },
  dashed: {
    display: "flex",
    flexDirection: "column",
    position: "relative",
    "::before": {
      backgroundImage:
        "repeating-linear-gradient(90deg, var(--color-border-default) 0 15px, transparent 0 30px)",
      content: "''",
      height: "1px",
      inset: "0 0 auto",
      pointerEvents: "none",
      position: "absolute",
    },
    "::after": {
      backgroundImage:
        "repeating-linear-gradient(90deg, var(--color-border-default) 0 15px, transparent 0 30px)",
      content: "''",
      height: "1px",
      inset: "auto 0 0",
      pointerEvents: "none",
      position: "absolute",
    },
  },
  stats: {
    borderBlockColor: colors.borderDefault,
    borderBlockStyle: "solid",
    borderBlockWidth: "1px",
    display: "grid",
    gridTemplateColumns: "1fr",
    placeItems: "stretch",
    position: "relative",
    "@media (min-width: 40rem)": { gridTemplateColumns: "repeat(3, 1fr)" },
  },
  stat: {
    alignItems: "center",
    borderBottomColor: colors.borderDefault,
    borderBottomStyle: "solid",
    borderBottomWidth: "1px",
    display: "flex",
    flexDirection: "column",
    justifyContent: "center",
    paddingBlock: spacing.xxl,
    "@media (min-width: 40rem)": {
      borderBottomWidth: 0,
      borderRightColor: colors.borderDefault,
      borderRightStyle: "solid",
      borderRightWidth: "1px",
    },
  },
  statLast: { "@media (min-width: 40rem)": { borderRightWidth: 0 } },
  statValue: {
    color: colors.textPrimary,
    fontSize: "1.875rem",
    fontWeight: typography.weightBold,
  },
  statLabel: { color: colors.textSecondary },
  cardButton: {
    alignItems: "center",
    display: "flex",
    fontWeight: typography.weightSemibold,
    gap: spacing.xs,
    justifyContent: "center",
    paddingBlock: spacing.xl,
    textDecoration: "none",
  },
  inlineIcon: { height: "1.25rem", width: "1.25rem" },
  projectCard: {
    borderBottomColor: colors.borderSubtle,
    borderBottomStyle: "solid",
    borderBottomWidth: "1px",
    display: "grid",
    gridTemplateColumns: "1fr 5rem",
    gridTemplateRows: "1fr",
    minHeight: "12rem",
    "@media (min-width: 40rem) and (max-width: 63.999rem)": {
      gridTemplateColumns: "1fr 10rem",
    },
    "@media (min-width: 64rem)": { gridTemplateColumns: "12rem 1fr 10rem" },
  },
  projectArtwork: {
    alignItems: "center",
    borderRightColor: colors.borderSubtle,
    borderRightStyle: "solid",
    borderRightWidth: "1px",
    display: "none",
    justifyContent: "center",
    paddingBlock: spacing.xxl,
    "@media (min-width: 64rem)": { display: "flex" },
  },
  projectBody: {
    borderRightColor: colors.borderSubtle,
    borderRightStyle: "solid",
    borderRightWidth: "1px",
    display: "flex",
    flexDirection: "column",
    gap: spacing.sm,
    justifyContent: "center",
    paddingBlock: spacing.xxl,
    paddingInline: spacing.xxl,
    "@media (min-width: 40rem)": { paddingInline: "3rem" },
  },
  projectArtworkMobile: {
    alignItems: "center",
    display: "flex",
    justifyContent: "flex-start",
    marginBottom: spacing.lg,
    "@media (min-width: 64rem)": { display: "none" },
  },
  projectDescription: { color: colors.textSecondary, margin: 0 },
  projectTitle: {
    fontSize: typography.sizeXl,
    fontWeight: typography.weightBold,
    margin: 0,
  },
  projectLinks: {
    color: colors.textSecondary,
    display: "grid",
    fontWeight: typography.weightBold,
    gridTemplateColumns: "1fr",
  },
  projectLink: {
    alignItems: "center",
    display: "flex",
    justifyContent: "center",
    textDecoration: "none",
    transitionDuration: motion.durationFast,
    transitionProperty: "background-color, color",
    ":hover": {
      backgroundColor: colors.surfaceInteractiveHover,
      color: colors.textPrimary,
    },
  },
  projectLinkBorder: {
    borderBottomColor: colors.borderSubtle,
    borderBottomStyle: "solid",
    borderBottomWidth: "1px",
  },
  linkContent: { display: "inline-flex", gap: spacing.sm },
  linkText: {
    display: "none",
    "@media (min-width: 40rem)": { display: "inline" },
  },
  projectIcon: { height: "1.5rem", width: "1.5rem" },
  contact: {
    alignItems: "flex-start",
    display: "flex",
    flexDirection: "column",
    gap: spacing.xl,
    justifyContent: "center",
    paddingInline: spacing.xxl,
    position: "relative",
    "@media (min-width: 40rem)": {
      alignItems: "center",
      flexDirection: "row",
      paddingInline: "2.5rem",
    },
  },
  contactTitle: {
    fontSize: "1.875rem",
    fontWeight: typography.weightBold,
    margin: 0,
  },
  contactList: { display: "flex", gap: spacing.lg },
  contactLink: {
    borderRadius: radii.round,
    height: "2.5rem",
    padding: spacing.sm,
    width: "2.5rem",
  },
  contactIcon: { color: "white", height: "1.5rem", width: "1.5rem" },
});
const iconAttrs = stylex.attrs(styles.inlineIcon);
const contactIconAttrs = stylex.attrs(styles.contactIcon);
const contactLinkAttrs = stylex.attrs(styles.contactLink);
const projectIconAttrs = stylex.attrs(styles.projectIcon);
---

<NavLayout seoConfig={seoConfig}>
  <Section style={styles.hero} bg="grid"
    ><div {...stylex.attrs(styles.heroRow)}>
      <Image
        src={logo}
        alt="logo"
        width={80}
        height={80}
        {...stylex.attrs(styles.logo)}
      /><h1 {...stylex.attrs(styles.heroTitle)}>{authorName}</h1>
    </div></Section
  >
  <Section style={styles.spacer} />
  <Section style={styles.featureSection}>
    <span {...stylex.attrs(styles.sectionNumber)}>01</span><h2
      {...stylex.attrs(styles.sectionTitle)}
    >
      文章
    </h2>
    <p {...stylex.attrs(styles.sectionDescription)}>
      从 {
        format(firstDate, "yyyy 年 M 月 d 日")
      }的第一篇文章开始，本站已经更新了……
    </p>
    <div {...stylex.attrs(styles.dashed)}>
      <div {...stylex.attrs(styles.stats)}>
        <div {...stylex.attrs(styles.stat)}>
          <div {...stylex.attrs(styles.statValue)}>
            {statistics.articles} 篇
          </div><div {...stylex.attrs(styles.statLabel)}>文章</div>
        </div>
        <div {...stylex.attrs(styles.stat)}>
          <div {...stylex.attrs(styles.statValue)}>
            {(statistics.words / 10000).toFixed(2)} 万
          </div><div {...stylex.attrs(styles.statLabel)}>字数</div>
        </div>
        <div {...stylex.attrs(styles.stat, styles.statLast)}>
          <div {...stylex.attrs(styles.statValue)}>
            {statistics.tags} 个
          </div><div {...stylex.attrs(styles.statLabel)}>标签</div>
        </div>
      </div><a
        {...stylex.attrs(styles.cardButton, layout.interactiveCard)}
        href="/post"
        >文章列表 <span
          class:list={[iconAttrs.class, "i-mingcute-external-link-line"]}
          style={iconAttrs.style}></span></a
      >
    </div>
  </Section>
  <Section style={styles.spacer} />
  <Section style={styles.featureSection}>
    <span {...stylex.attrs(styles.sectionNumber)}>02</span><h2
      {...stylex.attrs(styles.sectionTitle)}
    >
      项目
    </h2>
    <p {...stylex.attrs(styles.sectionDescription)}>
      在 <a href="https://github.com/yy4382" {...stylex.attrs(layout.underline)}
        >GitHub</a
      > 上有更多开源项目，不妨点个 Star 吧。
    </p>
    <div {...stylex.attrs(styles.dashed)}>
      {
        projects.map((project) => (
          <div {...stylex.attrs(styles.projectCard)}>
            <div {...stylex.attrs(styles.projectArtwork)}>
              <project.icon width={100} height={100} />
            </div>
            <div {...stylex.attrs(styles.projectBody)}>
              <>
                <div {...stylex.attrs(styles.projectArtworkMobile)}>
                  <project.icon width={64} height={64} />
                </div>
                <p {...stylex.attrs(styles.projectDescription)}>
                  {project.desc}
                </p>
                <h3 {...stylex.attrs(styles.projectTitle)}>{project.title}</h3>
              </>
            </div>
            <div {...stylex.attrs(styles.projectLinks)}>
              {project.links.map((link, index) => (
                <a
                  href={link.href}
                  target="_blank"
                  {...stylex.attrs(
                    styles.projectLink,
                    index !== project.links.length - 1 &&
                      styles.projectLinkBorder,
                  )}
                >
                  <span {...stylex.attrs(styles.linkContent)}>
                    <span
                      class:list={[link.icon, projectIconAttrs.class]}
                      style={projectIconAttrs.style}
                    />
                    <span {...stylex.attrs(styles.linkText)}>{link.text}</span>
                  </span>
                </a>
              ))}
            </div>
          </div>
        ))
      }
      <a
        {...stylex.attrs(styles.cardButton, layout.interactiveCard)}
        href="https://github.com/yy4382"
        >更多 <span
          class:list={[iconAttrs.class, "i-mingcute-external-link-line"]}
          style={iconAttrs.style}></span></a
      >
    </div>
  </Section>
  <Section style={styles.spacer} />
  <Section style={styles.contactSection}>
    <span {...stylex.attrs(styles.sectionNumber)}>03</span><div
      {...stylex.attrs(styles.contact)}
    >
      <h2 {...stylex.attrs(styles.contactTitle)}>联系我</h2><div
        {...stylex.attrs(styles.contactList)}
      >
        {
          contactInfo.map((contact) => (
            <a
              href={contact.link}
              target="_blank"
              aria-label={contact.name}
              class={contactLinkAttrs.class}
              style={`background-color: ${contact.color}`}
            >
              <span
                class:list={[contact.icon, contactIconAttrs.class]}
                style={contactIconAttrs.style}
              />
            </a>
          ))
        }
      </div>
    </div>
  </Section>
</NavLayout>
