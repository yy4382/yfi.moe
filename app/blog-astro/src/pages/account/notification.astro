---
import NavLayout from "@/components/layouts/NavLayout.astro";
import { Unsubscribe } from "@/components/modules/management/subscribe";
import { getSeo } from "@/lib/utils/SEO";
import { spacing, typography } from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";

const seoConfig = getSeo({
  title: "邮件通知设定",
  description: "邮件通知设定",
  noindex: true,
});

const styles = stylex.create({
  main: {
    display: "flex",
    flexDirection: "column",
    gap: spacing.lg,
    marginBlockStart: "2.5rem",
    marginInline: "auto",
    maxWidth: "28rem",
    minHeight: "80lvh",
    paddingInline: spacing.lg,
  },
  title: {
    fontSize: typography.sizeXxl,
    fontWeight: typography.weightBold,
    margin: 0,
  },
});
---

<NavLayout seoConfig={seoConfig} stopTrack>
  <main {...stylex.attrs(styles.main)}>
    <h1 {...stylex.attrs(styles.title)}>邮件通知设定</h1>
    <Unsubscribe client:only="react" />
  </main>
</NavLayout>
