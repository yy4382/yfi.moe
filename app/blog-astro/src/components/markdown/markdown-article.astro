---
import type { ArticleRenderResult } from "@repo/markdown/article";
import { toHtml } from "hast-util-to-html";
import { SKIP, visit } from "unist-util-visit";

import "@/styles/article-prose.css";
import { renderToString } from "react-dom/server";
import { createElement } from "react";
import {
  createArticleEmbeddedElement,
  isArticleEmbeddedElementName,
} from "./article-embedded-elements";

interface Props {
  hast: ArticleRenderResult["hast"];
}

const { hast } = Astro.props;

visit(hast, "element", (node, index, parent) => {
  if (!parent || index == null || !isArticleEmbeddedElementName(node.tagName)) {
    return;
  }

  parent.children.splice(index, 1, {
    type: "raw",
    value: renderToString(
      createElement("div", {
        "data-article-embedded-element": node.tagName,
        "data-props": JSON.stringify(node.properties),
        children: createArticleEmbeddedElement(node.tagName, node.properties),
      }),
    ),
  });
  return SKIP;
});

const html = toHtml(hast, { allowDangerousHtml: true });
---

<article set:html={html} id="article-content" class="article-prose" />

<script>
  import { hydrateRoot, type Root } from "react-dom/client";
  import {
    createArticleEmbeddedElement,
    isArticleEmbeddedElementName,
  } from "./article-embedded-elements";

  const roots: Root[] = [];

  function hydrate() {
    const elements = document.querySelectorAll<HTMLElement>(
      "[data-article-embedded-element]",
    );
    elements.forEach((element) => {
      const name = element.dataset.articleEmbeddedElement;
      if (!name || !isArticleEmbeddedElementName(name)) return;
      const properties = JSON.parse(element.dataset.props ?? "{}") as unknown;
      const root = hydrateRoot(
        element,
        createArticleEmbeddedElement(name, properties),
      );
      roots.push(root);
    });
  }

  function unmount() {
    roots.forEach((root) => {
      root.unmount();
    });
    roots.length = 0;
  }

  document.addEventListener("astro:page-load", hydrate);
  document.addEventListener("astro:after-swap", unmount);
</script>
