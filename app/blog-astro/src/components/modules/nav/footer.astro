---
import { siteConfig, siteDomain } from "@/config/site";
import { Image } from "astro:assets";
import logo from "@/assets/logo.png";
import {
  colors,
  radii,
  spacing,
  typography,
} from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

const iconAttrs = stylex.attrs(layout.iconSm);
const styles = stylex.create({
  root: {
    alignItems: "center",
    display: "flex",
    flexDirection: "column-reverse",
    gap: spacing.xl,
    justifyContent: "space-between",
    paddingBlock: spacing.lg,
    paddingInline: spacing.xl,
    "@media (min-width: 48rem)": { flexDirection: "row" },
  },
  brand: {
    display: "flex",
    fontSize: typography.sizeXxl,
    fontWeight: typography.weightBold,
    gap: spacing.lg,
    textDecoration: "none",
  },
  logo: { borderRadius: radii.lg, height: "2rem", width: "2rem" },
  content: {
    alignItems: "flex-start",
    display: "flex",
    flexDirection: "column",
    flexGrow: 1,
    flexShrink: 1,
    gap: spacing.xxl,
    width: "100%",
    "@media (min-width: 48rem)": {
      alignItems: "flex-end",
      gap: spacing.sm,
      width: "auto",
    },
  },
  links: {
    alignItems: "flex-start",
    alignSelf: "center",
    color: colors.textSecondary,
    display: "flex",
    flexDirection: "column",
    columnGap: spacing.xl,
    listStyle: "none",
    margin: 0,
    padding: 0,
    rowGap: spacing.xs,
    "@media (min-width: 48rem)": { alignSelf: "flex-end" },
    "@media (min-width: 64rem)": {
      alignItems: "flex-end",
      flexDirection: "row",
    },
  },
  linkGroup: {
    alignItems: "center",
    display: "inline-flex",
    fontWeight: typography.weightMedium,
  },
  inlineLinks: {
    display: "inline-flex",
    gap: spacing.sm,
    marginInlineStart: spacing.xs,
  },
  copyButton: {
    background: "transparent",
    border: 0,
    color: "inherit",
    cursor: "pointer",
    padding: 0,
  },
  legal: {
    alignItems: "center",
    alignSelf: "center",
    display: "flex",
    flexDirection: "column",
    fontSize: typography.sizeSm,
    "@media (min-width: 48rem)": {
      alignItems: "flex-end",
      alignSelf: "flex-end",
    },
  },
  legalRow: {
    alignItems: "center",
    color: colors.textSecondary,
    display: "inline-flex",
    gap: spacing.xs,
  },
  legalPiece: {
    alignItems: "center",
    display: "inline-flex",
    gap: spacing.xxs,
  },
  separator: { opacity: 0.7 },
  muted: { color: colors.textSecondary },
});
---

<div {...stylex.attrs(layout.mainContainer, styles.root)}>
  <a href="/" {...stylex.attrs(styles.brand)}>
    <Image
      src={logo}
      alt="logo"
      {...stylex.attrs(styles.logo)}
      width="32"
      height="32"
    />
    Yunfi
  </a>
  <div {...stylex.attrs(styles.content)}>
    <ul {...stylex.attrs(styles.links)}>
      <li>
        <span {...stylex.attrs(styles.linkGroup)}>
          关于 <span
            class:list={[iconAttrs.class, "i-lucide-chevron-right"]}
            style={iconAttrs.style}></span>
        </span>
        <span {...stylex.attrs(styles.inlineLinks)}>
          <a href="/about">关于我</a><a href="/about#关于本站">关于本站</a><a
            href="https://github.com/yy4382/yfi.moe">本站源码</a
          >
        </span>
      </li>
      <li>
        <span {...stylex.attrs(styles.linkGroup)}>
          联系 <span
            class:list={[iconAttrs.class, "i-lucide-chevron-right"]}
            style={iconAttrs.style}></span>
        </span>
        <span {...stylex.attrs(styles.inlineLinks)}>
          <button
            {...stylex.attrs(styles.copyButton)}
            data-copy-email
            data-email="yy4382@gmail.com">发邮件</button
          >
          <a href="https://t.me/YunfiDiscuz">Telegram</a><a
            href="https://github.com/yy4382">GitHub</a
          >
        </span>
      </li>
    </ul>
    <div {...stylex.attrs(styles.legal)}>
      <span {...stylex.attrs(styles.legalRow)}>
        <span {...stylex.attrs(styles.legalPiece)}>
          <span
            class:list={[iconAttrs.class, "i-lucide-copyright"]}
            style={iconAttrs.style}></span>
          2023-2024 <span
            ><a href={siteDomain} {...stylex.attrs(layout.underline)}>
              {siteConfig.title}</a
            >.</span
          >
        </span>
        <span {...stylex.attrs(styles.separator)}>|</span>
        <a href="/feed.xml" {...stylex.attrs(styles.legalPiece)}
          ><span
            class:list={[iconAttrs.class, "i-lucide-rss"]}
            style={iconAttrs.style}></span>RSS</a
        >
        <span {...stylex.attrs(styles.separator)}>|</span>
        <a href="/sitemap-index.xml" {...stylex.attrs(styles.legalPiece)}
          ><span
            class:list={[iconAttrs.class, "i-lucide-map"]}
            style={iconAttrs.style}></span>Site Map</a
        >
      </span>
      <span {...stylex.attrs(styles.muted)}
        >Powered by <a
          href="https://astro.build"
          {...stylex.attrs(layout.underline)}
        >
          Astro</a
        >. See all <a href="/credits" {...stylex.attrs(layout.underline)}>
          Credits</a
        >.</span
      >
    </div>
  </div>
</div>

<script>
  import { toast } from "sonner";
  function initCopyEmail() {
    document.querySelectorAll("[data-copy-email]").forEach((button) => {
      button.addEventListener("click", () => {
        const email = button.getAttribute("data-email");
        if (!email) return;
        navigator.clipboard.writeText(email).then(
          () => toast.success("复制邮箱成功"),
          () => toast.error("复制失败，可能您没有使用 HTTPS 访问"),
        );
      });
    });
  }
  document.addEventListener("astro:page-load", initCopyEmail);
</script>
