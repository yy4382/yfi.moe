---
import { contactInfo } from "@/config/author";
import {
  colors,
  motion,
  radii,
  spacing,
} from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";

const styles = stylex.create({
  list: {
    display: "flex",
    flexWrap: "wrap",
    gap: spacing.lg,
    marginBlock: spacing.lg,
  },
  link: {
    alignItems: "center",
    display: "inline-flex",
    gap: spacing.sm,
    textDecoration: "none",
    ":hover": { color: colors.accentText },
  },
  badge: {
    alignItems: "center",
    borderRadius: radii.round,
    display: "flex",
    height: "2.125rem",
    justifyContent: "center",
    padding: "0.375rem",
    transitionDuration: motion.durationFast,
    transitionProperty: "transform",
    width: "2.125rem",
    ":hover": { transform: "scale(1.05)" },
    ":active": { transform: "scale(0.95)" },
  },
  icon: { color: "white", height: "100%", width: "100%" },
});

const badgeAttrs = stylex.attrs(styles.badge);
const iconAttrs = stylex.attrs(styles.icon);
---

<div {...stylex.attrs(styles.list)}>
  {
    contactInfo.map((contact) => (
      <a
        data-unstyled-link
        href={contact.link}
        target="_blank"
        rel="noopener noreferrer"
        {...stylex.attrs(styles.link)}
      >
        <span
          aria-label={contact.name}
          class={badgeAttrs.class}
          style={`background-color: ${contact.color}`}
        >
          <span
            class:list={[contact.icon, iconAttrs.class]}
            style={iconAttrs.style}
          />
        </span>
        <span>{contact.name}</span>
      </a>
    ))
  }
</div>
