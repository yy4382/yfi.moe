---
import { getSeriesPosts } from "@/lib/utils/content";
import Section from "@/components/ui/section.astro";
import {
  colors,
  motion,
  spacing,
  typography,
} from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

const { seriesId, currentSlug } = Astro.props as {
  seriesId: string;
  currentSlug: string;
};
const seriesPosts = await getSeriesPosts(seriesId);
if (seriesPosts.length <= 1) return null;
const iconAttrs = stylex.attrs(layout.iconSm);
const styles = stylex.create({
  section: { paddingBlock: "2.5rem" },
  heading: {
    alignItems: "center",
    display: "flex",
    gap: spacing.sm,
    marginBottom: spacing.lg,
  },
  title: {
    fontSize: typography.sizeMd,
    fontWeight: typography.weightSemibold,
    margin: 0,
  },
  list: {
    display: "flex",
    flexDirection: "column",
    gap: spacing.md,
    listStyle: "none",
    margin: 0,
    padding: 0,
  },
  item: { margin: 0, padding: 0 },
  entry: {
    alignItems: "flex-start",
    display: "flex",
    gap: spacing.sm,
    lineHeight: typography.lineRelaxed,
    textDecoration: "none",
  },
  active: { color: colors.accentText, fontWeight: typography.weightMedium },
  link: {
    transitionDuration: motion.durationFast,
    transitionProperty: "color",
    ":hover": { color: colors.accentText },
  },
  number: {
    color: colors.textSecondary,
    flexShrink: 0,
    fontWeight: typography.weightRegular,
  },
});
---

<Section contentStyle={styles.section} padding="article"
  ><div {...stylex.attrs(layout.articleWidth)}>
    <div {...stylex.attrs(styles.heading)}>
      <span
        class:list={[iconAttrs.class, "i-lucide-list"]}
        style={iconAttrs.style}></span><h3 {...stylex.attrs(styles.title)}>
        系列文章
      </h3>
    </div><ol {...stylex.attrs(styles.list)}>
      {
        seriesPosts.map((post, index) => {
          const current = post.id === currentSlug;
          return (
            <li {...stylex.attrs(styles.item)}>
              {current ? (
                <div {...stylex.attrs(styles.entry, styles.active)}>
                  <span {...stylex.attrs(styles.number)}>{index + 1}.</span>
                  <span>{post.data.title}</span>
                </div>
              ) : (
                <a
                  href={`/post/${post.id}`}
                  {...stylex.attrs(styles.entry, styles.link)}
                >
                  <span {...stylex.attrs(styles.number)}>{index + 1}.</span>
                  <span>{post.data.title}</span>
                </a>
              )}
            </li>
          );
        })
      }
    </ol>
  </div></Section
>
