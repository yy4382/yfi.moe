---
import { getSimilarPosts } from "@/lib/utils/content";
import {
  colors,
  motion,
  spacing,
  typography,
} from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

interface Props {
  currentSlug: string;
  limit?: number;
}

const { currentSlug, limit = 3 } = Astro.props;
const similarPosts = await getSimilarPosts(currentSlug, limit);

const styles = stylex.create({
  headingRow: {
    borderBottomColor: colors.borderDefault,
    borderBottomStyle: "solid",
    borderBottomWidth: "1px",
    paddingBlock: spacing.lg,
    paddingInline: spacing.xl,
  },
  heading: {
    fontSize: typography.sizeLg,
    fontWeight: typography.weightMedium,
    margin: 0,
  },
  grid: {
    display: "grid",
    gridTemplateColumns: "1fr",
    "@media (min-width: 48rem)": {
      gridTemplateColumns: "repeat(3, minmax(0, 1fr))",
    },
  },
  card: {
    containerType: "inline-size",
    display: "flex",
    flexDirection: "column",
    gap: spacing.sm,
    paddingBlock: spacing.xl,
    paddingInline: spacing.xl,
    textDecoration: "none",
    transitionDuration: motion.durationFast,
    transitionProperty: "background-color, color",
    transitionTimingFunction: motion.easeStandard,
    ":hover": {
      backgroundColor: colors.surfaceInteractiveHover,
      color: colors.accentText,
    },
    "@container (min-width: 20rem)": {
      paddingBlock: spacing.xxl,
      paddingInline: spacing.xxl,
    },
  },
  divider: {
    borderBottomColor: colors.borderDefault,
    borderBottomStyle: "solid",
    borderBottomWidth: "1px",
    "@media (min-width: 48rem)": {
      borderBottomWidth: 0,
      borderRightColor: colors.borderDefault,
      borderRightStyle: "solid",
      borderRightWidth: "1px",
    },
  },
  title: {
    fontWeight: typography.weightMedium,
    lineHeight: typography.lineNormal,
    margin: 0,
    transitionDuration: motion.durationFast,
    transitionProperty: "color",
  },
  tags: {
    alignItems: "center",
    color: colors.textSecondary,
    display: "flex",
    fontSize: typography.sizeSm,
    marginBlockStart: "auto",
    paddingBlockStart: spacing.sm,
    userSelect: "none",
  },
  hash: { height: "1rem", marginInlineEnd: spacing.xs, width: "1rem" },
  tagList: { display: "inline-flex", gap: spacing.xs },
});

const hashAttrs = stylex.attrs(styles.hash);
---

{
  similarPosts.length > 0 && (
    <div {...stylex.attrs(layout.sectionBorder)}>
      <div {...stylex.attrs(layout.mainContainer)}>
        <div {...stylex.attrs(styles.headingRow)}>
          <h2 {...stylex.attrs(styles.heading)}>相关推荐</h2>
        </div>
        <div {...stylex.attrs(styles.grid)}>
          {similarPosts.map(({ post }, index) => (
            <a
              href={`/post/${post.id}`}
              {...stylex.attrs(
                styles.card,
                index < similarPosts.length - 1 && styles.divider,
              )}
            >
              <h3 {...stylex.attrs(styles.title)}>{post.data.title}</h3>
              {post.data.tags.length > 0 && (
                <div {...stylex.attrs(styles.tags)}>
                  <span
                    class:list={[hashAttrs.class, "i-lucide-hash"]}
                    style={hashAttrs.style}
                  />
                  <span {...stylex.attrs(styles.tagList)}>
                    {post.data.tags.slice(0, 3).map((tag, tagIndex) => (
                      <Fragment>
                        {tagIndex !== 0 && <span>|</span>}
                        <span>{tag}</span>
                      </Fragment>
                    ))}
                  </span>
                </div>
              )}
            </a>
          ))}
        </div>
      </div>
    </div>
  )
}
