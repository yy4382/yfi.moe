---
import { getAdjacentPosts } from "@/lib/utils/content";
import {
  colors,
  motion,
  spacing,
  typography,
} from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const { prev, next } = await getAdjacentPosts(currentSlug);

const styles = stylex.create({
  grid: { display: "grid", gridTemplateColumns: "1fr" },
  container: { containerType: "inline-size" },
  pairedGrid: {
    "@media (min-width: 64rem)": {
      gridTemplateColumns: "repeat(2, minmax(0, 1fr))",
    },
  },
  card: {
    alignItems: "center",
    display: "flex",
    gap: spacing.lg,
    height: "100%",
    paddingBlock: spacing.xl,
    paddingInline: spacing.xl,
    textDecoration: "none",
    transitionDuration: motion.durationFast,
    transitionProperty: "background-color, color",
    transitionTimingFunction: motion.easeStandard,
    ":hover": {
      backgroundColor: colors.surfaceInteractiveHover,
      color: colors.accentText,
    },
    "@container (min-width: 32rem)": {
      gap: spacing.xxl,
      paddingBlock: spacing.xxl,
      paddingInline: "4rem",
    },
  },
  prevPaired: {
    borderBottomColor: colors.borderDefault,
    borderBottomStyle: "solid",
    borderBottomWidth: "1px",
    "@media (min-width: 64rem)": {
      borderBottomWidth: 0,
      borderRightColor: colors.borderDefault,
      borderRightStyle: "solid",
      borderRightWidth: "1px",
    },
  },
  nextCard: { flexDirection: "row-reverse" },
  iconCircle: {
    alignItems: "center",
    backgroundColor: "color-mix(in srgb, var(--color-accent) 10%, transparent)",
    borderColor: "color-mix(in srgb, var(--color-accent) 20%, transparent)",
    borderRadius: "9999px",
    borderStyle: "solid",
    borderWidth: "1px",
    display: "flex",
    flexShrink: 0,
    height: "3rem",
    justifyContent: "center",
    transitionDuration: motion.durationNormal,
    transitionProperty: "background-color, border-color",
    width: "3rem",
  },
  icon: {
    height: "2.25rem",
    transitionDuration: motion.durationNormal,
    transitionProperty: "transform",
    width: "2.25rem",
    ":hover": { transform: "scale(1.2)" },
    ":active": { transform: "scale(0.95)" },
  },
  text: { minWidth: 0 },
  nextText: {
    alignItems: "flex-end",
    display: "flex",
    flexDirection: "column",
    textAlign: "end",
  },
  eyebrow: {
    color: colors.textSecondary,
    fontSize: typography.sizeSm,
    margin: 0,
  },
  title: {
    margin: 0,
    "@container (min-width: 32rem)": { fontSize: typography.sizeLg },
  },
});

const iconAttrs = stylex.attrs(styles.icon);
---

{
  (prev || next) && (
    <div {...stylex.attrs(layout.sectionBorder)}>
      <div
        {...stylex.attrs(
          layout.mainContainer,
          styles.grid,
          prev && next && styles.pairedGrid,
        )}
      >
        {prev && (
          <div {...stylex.attrs(styles.container)}>
            <a
              {...stylex.attrs(styles.card, next && styles.prevPaired)}
              href={`/post/${prev.id}`}
            >
              <div {...stylex.attrs(styles.iconCircle)}>
                <span
                  class:list={[iconAttrs.class, "i-lucide-chevron-left"]}
                  style={iconAttrs.style}
                />
              </div>
              <div {...stylex.attrs(styles.text)}>
                <p {...stylex.attrs(styles.eyebrow)}>上一篇</p>
                <p {...stylex.attrs(styles.title)}>{prev.data.title}</p>
              </div>
            </a>
          </div>
        )}
        {next && (
          <div {...stylex.attrs(styles.container)}>
            <a
              {...stylex.attrs(styles.card, styles.nextCard)}
              href={`/post/${next.id}`}
            >
              <div {...stylex.attrs(styles.iconCircle)}>
                <span
                  class:list={[iconAttrs.class, "i-lucide-chevron-right"]}
                  style={iconAttrs.style}
                />
              </div>
              <div {...stylex.attrs(styles.text, styles.nextText)}>
                <p {...stylex.attrs(styles.eyebrow)}>下一篇</p>
                <p {...stylex.attrs(styles.title)}>{next.data.title}</p>
              </div>
            </a>
          </div>
        )}
      </div>
    </div>
  )
}
