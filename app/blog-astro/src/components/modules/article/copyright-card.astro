---
import Sign from "@/assets/signature-yunfi.svg?raw";
import Section from "@/components/ui/section.astro";
import "@/styles/signature.css";
import { colors, spacing, typography } from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";

const styles = stylex.create({
  section: { overflow: "hidden", paddingBlock: "2.5rem" },
  content: {
    color: colors.textSecondary,
    fontSize: typography.sizeSm,
    lineHeight: typography.lineRelaxed,
    marginInline: "auto",
    maxWidth: "75ch",
  },
  paragraph: { marginBlock: 0 },
  firstParagraph: { marginBlockEnd: spacing.sm },
  signature: { float: "inline-end" },
  link: {
    color: colors.textPrimary,
    textDecoration: "underline",
    textDecorationColor: colors.borderStrong,
    textUnderlineOffset: "0.2em",
    ":hover": { color: colors.accentText },
  },
});
const signatureAttrs = stylex.attrs(styles.signature);
---

<Section contentStyle={styles.section} padding="article">
  <div {...stylex.attrs(styles.content)}>
    <div
      class:list={["article-signature", signatureAttrs.class]}
      style={signatureAttrs.style}
    >
      <Fragment set:html={Sign} />
    </div>
    <p {...stylex.attrs(styles.paragraph, styles.firstParagraph)}>
      本文使用“<a
        {...stylex.attrs(styles.link)}
        href="https://creativecommons.org/licenses/by-nc-sa/4.0/deed.en"
        >署名-非商业性使用-相同方式共享 4.0 国际(CC BY-NC-SA 4.0)</a
      >”进行许可。
    </p>
    <p {...stylex.attrs(styles.paragraph)}>
      商业转载请联系站长获得授权，非商业转载请注明本文出处及文章链接。
      如果您再混合、转换或者基于本作品进行创作，您必须基于<a
        {...stylex.attrs(styles.link)}
        href="https://creativecommons.org/share-your-work/licensing-considerations/compatible-licenses/"
        >相同的</a
      >协议分发您贡献的作品。
    </p>
  </div>
</Section>
