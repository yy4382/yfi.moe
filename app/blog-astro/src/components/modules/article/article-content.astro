---
import { getCollection } from "astro:content";
import { renderArticle, type ImageMetadata } from "@repo/markdown/article";
import MarkdownArticle from "@/components/markdown/markdown-article.astro";
import Toc from "./toc/Toc";
import ReadingProgress from "./reading-progress";
import { spacing } from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

const { text } = Astro.props as { text: string };
const imageMetadata = (await getCollection("imageMeta")).map(
  (entry) => entry.data,
) as ImageMetadata[];
const { hast, outline } = await renderArticle(text, { imageMetadata });
const styles = stylex.create({
  container: {
    containerType: "inline-size",
    display: "grid",
    gridTemplateColumns: "1fr",
    height: "100%",
    position: "relative",
  },
  overlay: { gridColumnStart: 1, gridRowStart: 1, pointerEvents: "none" },
  article: {
    gridColumnStart: 1,
    gridRowStart: 1,
    paddingBlock: "4.5rem",
    paddingInline: spacing.lg,
  },
});
---

<div {...stylex.attrs(layout.sectionBorder)}>
  <div
    id="article-container"
    {...stylex.attrs(layout.mainContainer, styles.container)}
  >
    <div {...stylex.attrs(styles.overlay)}>
      <ReadingProgress client:load client:only="react" />
    </div>
    <div {...stylex.attrs(styles.overlay)}>
      <Toc headings={outline} client:load client:only="react" />
    </div>
    <div {...stylex.attrs(styles.article)}><MarkdownArticle hast={hast} /></div>
  </div>
</div>
