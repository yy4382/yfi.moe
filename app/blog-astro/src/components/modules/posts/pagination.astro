---
import Section from "@/components/ui/section.astro";
import {
  colors,
  motion,
  radii,
  spacing,
  typography,
} from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

interface Props {
  currentPage: number;
  totalPages: number;
  baseUrl: string;
}
const { currentPage, totalPages, baseUrl } = Astro.props;
if (totalPages <= 1) return null;
const HIDDEN = -1,
  ADJ_DIST = 2,
  VISIBLE = ADJ_DIST * 2 + 1;
let count = 1,
  l = currentPage,
  r = currentPage;
while (0 < l - 1 && r + 1 <= totalPages && count + 2 <= VISIBLE) {
  count += 2;
  l--;
  r++;
}
while (0 < l - 1 && count < VISIBLE) {
  count++;
  l--;
}
while (r + 1 <= totalPages && count < VISIBLE) {
  count++;
  r++;
}
const pages: number[] = [];
if (l > 1) pages.push(1);
if (l === 3) pages.push(2);
if (l > 3) pages.push(HIDDEN);
for (let i = l; i <= r; i++) pages.push(i);
if (r < totalPages - 2) pages.push(HIDDEN);
if (r === totalPages - 2) pages.push(totalPages - 1);
if (r < totalPages) pages.push(totalPages);
const buildPageUrl = (page: number) =>
  page === 1 ? baseUrl : `${baseUrl}/${page}`;
const prevPage = currentPage > 1 ? currentPage - 1 : undefined;
const nextPage = currentPage < totalPages ? currentPage + 1 : undefined;
const iconAttrs = stylex.attrs(layout.iconLg);
const styles = stylex.create({
  root: {
    display: "flex",
    flexDirection: "row",
    gap: spacing.md,
    justifyContent: "center",
  },
  arrow: {
    alignItems: "center",
    borderRadius: radii.round,
    color: colors.textPrimary,
    display: "flex",
    height: "3rem",
    justifyContent: "center",
    overflow: "hidden",
    textDecoration: "none",
    transitionDuration: motion.durationFast,
    transitionProperty: "background-color, color",
    width: "3rem",
    ":hover": {
      backgroundColor: colors.surfaceInteractiveHover,
      color: colors.accentText,
    },
  },
  disabled: { cursor: "not-allowed", opacity: 0.5, pointerEvents: "none" },
  pages: {
    alignItems: "center",
    display: "flex",
    flexDirection: "row",
    fontWeight: typography.weightBold,
    gap: spacing.sm,
  },
  page: {
    alignItems: "center",
    borderRadius: radii.round,
    display: "flex",
    height: "2.25rem",
    justifyContent: "center",
    textDecoration: "none",
    transitionDuration: motion.durationFast,
    width: "2.25rem",
    ":hover": {
      backgroundColor: colors.surfaceInteractiveHover,
      color: colors.accentText,
    },
  },
  current: { backgroundColor: colors.accent, color: colors.textOnAccent },
  more: { height: "1.25rem", marginInline: spacing.xs, width: "1.25rem" },
});
---

<Section padding="sm">
  <div {...stylex.attrs(styles.root)}>
    <a
      href={prevPage ? buildPageUrl(prevPage) : undefined}
      aria-label={prevPage ? "Previous Page" : undefined}
      aria-disabled={!prevPage}
      {...stylex.attrs(styles.arrow, !prevPage && styles.disabled)}
    >
      <span
        class:list={[iconAttrs.class, "i-lucide-chevron-left"]}
        style={iconAttrs.style}></span>
    </a>
    <div {...stylex.attrs(styles.pages)}>
      {
        pages.map((page) =>
          page === HIDDEN ? (
            <span
              class="i-lucide-more-horizontal"
              {...stylex.attrs(styles.more)}
            />
          ) : page === currentPage ? (
            <span {...stylex.attrs(styles.page, styles.current)}>{page}</span>
          ) : (
            <a
              href={buildPageUrl(page)}
              aria-label={`Page ${page}`}
              {...stylex.attrs(styles.page)}
            >
              {page}
            </a>
          ),
        )
      }
    </div>
    <a
      href={nextPage ? buildPageUrl(nextPage) : undefined}
      aria-label={nextPage ? "Next Page" : undefined}
      aria-disabled={!nextPage}
      {...stylex.attrs(styles.arrow, !nextPage && styles.disabled)}
    >
      <span
        class:list={[iconAttrs.class, "i-lucide-chevron-right"]}
        style={iconAttrs.style}></span>
    </a>
  </div>
</Section>
