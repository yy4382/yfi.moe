---
import { type SEOProps, SEO } from "astro-seo";
import { siteConfig } from "@/config/site";

import "@/styles/global.css";
import "@/styles/icons.css";

import { ClientRouter } from "astro:transitions";
import Favicon from "@/components/html-head/Favicon.astro";
import TagManagers from "@/components/html-head/TagManager.astro";
// @ts-expect-error fontFamilyFallback is not correctly typed
import { css, fontFamilyFallback } from "@/assets/fonts/MiSansVF.ttf";
import { Toaster } from "sonner";
import { colors, typography } from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";

interface Props {
  seoConfig: SEOProps;
  stopTrack?: boolean;
}

const styles = stylex.create({
  body: {
    backgroundColor: colors.canvas,
    backgroundAttachment: "fixed",
    color: colors.textPrimary,
    letterSpacing: typography.trackingNormal,
    margin: 0,
    overflowX: "hidden",
    padding: 0,
  },
  progress: {
    backgroundColor: "hsl(236 100% 81%)",
    height: "2px",
    inset: "0 auto auto 0",
    opacity: 0,
    pointerEvents: "none",
    position: "fixed",
    transform: "scaleX(0)",
    transformOrigin: "left",
    transitionDuration: "280ms, 180ms",
    transitionProperty: "transform, opacity",
    transitionTimingFunction: "cubic-bezier(0.22, 1, 0.36, 1), ease-out",
    width: "100%",
    zIndex: 2147483647,
    ":is([data-state='loading'])": {
      opacity: 1,
      transform: "scaleX(0.82)",
      transitionDuration: "900ms, 120ms",
    },
    ":is([data-state='done'])": { opacity: 0, transform: "scaleX(1)" },
    "@media (prefers-reduced-motion: reduce)": { transition: "none" },
  },
});

const appFontStack =
  'var(--app-font-family), "SF Pro", var(--app-font-fallback)';
const appTypography = stylex.createTheme(typography, {
  bodyFamily: appFontStack,
  "--font-body": appFontStack,
});

const { seoConfig, stopTrack } = Astro.props;
const bodyAttrs = stylex.attrs(styles.body, appTypography);
---

<html lang="zh-Hans">
  <head>
    <meta charset="utf-8" />
    <Favicon />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="alternate" type="application/rss+xml" href="/feed.xml" />
    <!-- <script src="https://unpkg.com/react-scan/dist/auto.global.js"></script> -->
    {import.meta.env.PROD && !stopTrack && <TagManagers />}
    <SEO
      {...seoConfig}
      titleTemplate={"%s - " + siteConfig.title}
      titleDefault={siteConfig.title}
      canonical={Astro.url.href.replace(/\/$/, "")}
    />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <ClientRouter fallback="swap" />
  </head>
  <body
    class={bodyAttrs.class}
    style={`--app-font-family: ${css.family}; --app-font-fallback: ${fontFamilyFallback}`}
  >
    <div
      id="route-progress"
      aria-hidden="true"
      {...stylex.attrs(styles.progress)}
    >
    </div>
    <slot />
    <Toaster theme="system" client:load />
    <script>
      const routeProgressBoundKey = "__yfiRouteProgressBound";
      const getRouteProgress = () => document.getElementById("route-progress");

      if (!Reflect.get(window, routeProgressBoundKey)) {
        Reflect.set(window, routeProgressBoundKey, true);

        document.addEventListener("astro:before-preparation", () => {
          const progress = getRouteProgress();
          progress?.setAttribute("data-state", "loading");
        });

        const completeProgress = () => {
          const progress = getRouteProgress();
          progress?.setAttribute("data-state", "done");
          window.setTimeout(() => {
            if (progress?.getAttribute("data-state") === "done") {
              progress.removeAttribute("data-state");
            }
          }, 280);
        };

        document.addEventListener("astro:after-swap", completeProgress);
        document.addEventListener("astro:page-load", completeProgress);
      }
    </script>
  </body>
</html>
