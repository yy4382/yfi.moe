---
import { getSeo } from "@/lib/utils/SEO";
import NavLayout from "@/components/layouts/NavLayout.astro";
import ArticleHero from "@/components/modules/article/article-hero.astro";
import Comment from "@/components/modules/comments/comment.astro";
import "@/styles/article-prose.css";
import { spacing } from "@repo/design-tokens/tokens.stylex";
import * as stylex from "@stylexjs/stylex";
import { layout } from "@/styles/shared.stylex";

import type { MarkdownLayoutProps } from "astro";

type Props = MarkdownLayoutProps<{
  // 在这里定义 frontmatter 属性
  title: string;
  description?: string;
  useComment?: boolean;
}>;

const { frontmatter: page } = Astro.props;

const seoConfig = getSeo({
  title: page.title,
  description: page.description,
  type: "article",
});

const styles = stylex.create({
  content: { paddingBlock: "4.5rem", paddingInline: spacing.lg },
});
const articleAttrs = stylex.attrs(layout.articleWidth);
---

<NavLayout seoConfig={seoConfig}>
  <ArticleHero title={page.title} />
  <div {...stylex.attrs(layout.sectionBorder)}>
    <div {...stylex.attrs(layout.mainContainer)}>
      <div {...stylex.attrs(styles.content)}>
        <div
          class:list={["article-prose", articleAttrs.class]}
          style={articleAttrs.style}
        >
          <slot />
        </div>
      </div>
    </div>
  </div>
  {page.useComment && <Comment />}
</NavLayout>
