{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/assets/(.*).woff2",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400, s-maxage=604800"
        }
      ]
    }
  ],
  "framework": null,
  "buildCommand": "TURBO_TELEMETRY_DISABLED=1 pnpm build:start"
}
